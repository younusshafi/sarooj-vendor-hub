      {
        "id": "prep",
        "name": "Prepare Vendor Loop",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          1540,
          420
        ],
        "parameters": {
          "jsCode": "const sel = $('Validate Input').first().json.selected_vendor_ids;\nconst allow = Array.isArray(sel) ? new Set(sel) : null;\n// B1 SAFETY GATE: subcontractor dispatch emails ONLY explicitly-selected vendors.\n// No selection (null/empty) => send to NONE (never send-to-all).\nconst seen=new Set(); const out=[];\nif(allow && allow.size>0){\n  for(const v of $('Fetch Vendors').all()){\n    const j=v.json;\n    if(!j||!j.id||!j.email_to||seen.has(j.id))continue;\n    if(!allow.has(j.vendor_id))continue;   // gate on vendor_id\n    seen.add(j.id); out.push({json:j});\n  }\n}\nreturn out;\n"
        }
      },
