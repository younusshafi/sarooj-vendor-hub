    {
      "id": "bemail",
      "name": "Build Email Body",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1980,
        560
      ],
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const v=$('Loop Vendors').item.json;\nconst rfq=$('Fetch RFQ').first().json;\nconst deadline=$('Validate Input').first().json.deadline||'[To be confirmed]';\nconst name=v.contact_person||'Sir';\nconst sender=rfq.created_by||'Procurement Department';\nlet body=rfq.covering_email_body||'';\nbody=body.split('[Contact Person]').join(name);\nbody=body.split('[SENDER_NAME]').join(sender);\nbody=body.split('[DEADLINE]').join(deadline);\nreturn {json:{email_to:v.email_to, contact_person:name, subject:rfq.covering_email_subject, body}};"
      }
